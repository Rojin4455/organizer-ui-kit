+                                    "text-sm font-semibold tracking-tight",
+                                    isActive ? "text-foreground" : "text-muted-foreground"
+                                )}
+                            >
+                                {step.title}
+                            </span>
+                            <span
+                                className={cn(
+                                    "text-xs",
+                                    isActive ? "text-muted-foreground" : "text-muted-foreground/70"
